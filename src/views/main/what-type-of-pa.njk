{% extends "base.njk" %}

{% block content %}
  <div class="govuk-width-container">
      <div class="govuk-grid-row">
        <div class="govuk-grid-column-two-thirds">
          <h1 class="govuk-heading-xl">Apply for civil legal aid</h1>

          <p class="govuk-body">What type of prior authority are you applying for?</p>

          <ul class="govuk-list govuk-list--bullet">
            <li>Expert</li>
            <li>Expense</li>
            <li>Counsel</li>
          </ul>

    <a href="apply-sca-and-other" role="button" draggable="false" class="govuk-button govuk-button--start" data-module="govuk-button" data-govuk-button-init="">
        Save and continue
        <svg class="govuk-button__start-icon" xmlns="http://www.w3.org/2000/svg" width="17.5" height="19" viewBox="0 0 33 40" aria-hidden="true" focusable="false">
              <path fill="currentColor" d="M0 0h13l20 20-20 20H0l20-20z"></path>
            </svg>
          </a>
    <a href="apply-sca-and-other" role="button" draggable="false" class="govuk-button govuk-button--start" data-module="govuk-button" data-govuk-button-init="">
        Save and come back later
        <svg class="govuk-button__start-icon" xmlns="http://www.w3.org/2000/svg" width="17.5" height="19" viewBox="0 0 33 40" aria-hidden="true" focusable="false">
              <path fill="currentColor" d="M0 0h13l20 20-20 20H0l20-20z"></path>
            </svg>
          </a>
        </div>
      </div>
    </div>
{% endblock %}