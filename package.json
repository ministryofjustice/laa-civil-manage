{
  "name": "laa-express-typescript-template",
  "version": "1.0.1",
  "private": true,
  "license": "MIT",
  "main": "public/index.js",
  "type": "module",
  "imports": {
    "#*": "./*"
  },
  "scripts": {
    "start": "node public/index.js",
    "clean": "rimraf public",
    "build": "yarn clean && yarn build:ts && node public/esbuild.js",
    "lint": "yarn eslint . --fix",
    "lint:check": "yarn eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "yarn build:ts && concurrently \"tsc --watch\" \"node public/esbuild.js --watch\" \"nodemon\"",
    "deploy": "./scripts/deploy.sh",
    "prepare": "husky",
    "tsc": "tsc --noEmit",
    "build:ts": "tsc",
    "test": "yarn test:unit && yarn test:e2e",
    "test:unit": "./node_modules/.bin/mocha",
    "test:e2e": "yarn playwright test --config=tests/playwright/playwright.config.ts",
    "coverage": "c8 yarn test:unit --check-coverage"
  },
  "engines": {
    "node": "25.7.0"
  },
  "dependencies": {
    "@azure/msal-node": "^5.0.4",
    "@ministryofjustice/frontend": "^9.0.0",
    "axios": "1.13.5",
    "body-parser": "^2.2.2",
    "chalk": "^5.6.2",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "~1.4.6",
    "csrf-sync": "^4.2.1",
    "debug": "~4.4.3",
    "dotenv": "^17.3.1",
    "eslint-plugin-mocha": "^11.2.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "figlet": "^1.10.0",
    "fs-extra": "^11.3.3",
    "govuk-frontend": "^5.13.0",
    "helmet": "^8.1.0",
    "http-errors": "~2.0.1",
    "i18next": "^25.8.11",
    "jwks-rsa": "^3.2.2",
    "libphonenumber-js": "^1.12.38",
    "moment": "^2.30.1",
    "morgan": "~1.10.1",
    "nunjucks": "^3.2.4",
    "redis": "^5.11.0",
    "ts-sinon": "^2.0.2",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^9.36.0",
    "@playwright/test": "^1.58.2",
    "@types/chai": "^5.2.3",
    "@types/compression": "^1.7.5",
    "@types/connect-livereload": "^0.6.3",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/express-session": "^1.18.1",
    "@types/figlet": "^1.7.0",
    "@types/fs-extra": "^11.0.4",
    "@types/jsdom": "^28.0.0",
    "@types/livereload": "^0.9.5",
    "@types/mocha": "^10.0.10",
    "@types/morgan": "^1.9.9",
    "@types/node": "^25.3.2",
    "@types/nunjucks": "^3.2.6",
    "@types/sinon": "^21.0.0",
    "@types/supertest": "^7.2.0",
    "@types/validator": "^13.15.10",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "axe-core": "^4.11.1",
    "c8": "^11.0.0",
    "chai": "^6.2.2",
    "chokidar": "5.0.0",
    "concurrently": "^9.2.1",
    "connect-livereload": "^0.6.1",
    "cross-env": "^10.1.0",
    "esbuild": "^0.27.3",
    "esbuild-plugin-copy": "^2.1.1",
    "esbuild-sass-plugin": "^3.6.0",
    "eslint": "^9.39.3",
    "eslint-config-love": "^151.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jsdoc": "^62.6.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "livereload": "^0.10.2",
    "middleware-axios": "^3.0.0",
    "mocha": "^11.7.5",
    "msw": "^2.12.10",
    "nodemon": "^3.1.13",
    "playwright-core": "^1.58.2",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sass": "^1.97.3",
    "sass-embedded": "^1.97.3",
    "sinon": "^21.0.1",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "packageManager": "yarn@4.12.0"
}
