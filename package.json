{
  "name": "laa-express-typescript-template",
  "version": "1.0.1",
  "private": true,
  "license": "MIT",
  "main": "public/index.js",
  "type": "module",
  "imports": {
    "#*": "./*"
  },
  "overrides": {
    "picomatch": "^4.0.0"
  },
  "scripts": {
    "start": "bun public/index.js",
    "clean": "rimraf public",
    "build": "bun run clean && bun esbuild.ts",
    "lint": "bunx eslint . --fix",
    "lint:check": "bunx eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "concurrently \"bun esbuild.ts --watch\" \"bun --watch src/index.ts\"",
    "deploy": "./scripts/deploy.sh",
    "prepare": "husky",
    "security:zap:ci": "./deploy/scripts/zap/zap-run-cicd.sh",
    "security:zap:local": "./deploy/scripts/zap/zap-run-local.sh",
    "test": "bun test ./tests/unit",
    "test:playwright": "mise build; bunx playwright test",
    "pretest:playwright": "docker rm -f wiremock-pw || true"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.2",
    "@ministryofjustice/frontend": "^9.0.0",
    "@playwright/test": "^1.59.1",
    "axios": "1.15.2",
    "chalk": "^5.6.2",
    "connect-redis": "^9.0.0",
    "cookie-parser": "~1.4.7",
    "dotenv": "^17.4.2",
    "eslint-plugin-unused-imports": "^4.4.1",
    "express": "^5.2.1",
    "express-prom-bundle": "^8.0.0",
    "express-rate-limit": "^8.3.2",
    "express-session": "^1.19.0",
    "fs-extra": "^11.3.4",
    "govuk-frontend": "^6.1.0",
    "i18next": "^26.0.4",
    "jwks-rsa": "^4.0.1",
    "nunjucks": "^3.2.4",
    "prom-client": "^15.1.3",
    "redis": "^5.12.1"
  },
  "devDependencies": {
    "@types/bun": "1.3.13",
    "@types/connect-livereload": "0.6.3",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/express-session": "1.19.0",
    "@types/fs-extra": "11.0.4",
    "@types/node": "25.6.0",
    "@types/nunjucks": "3.2.6",
    "@typescript-eslint/eslint-plugin": "8.59.0",
    "@typescript-eslint/parser": "8.59.0",
    "axe-core": "4.11.3",
    "chokidar": "5.0.0",
    "concurrently": "9.2.1",
    "connect-livereload": "0.6.1",
    "cross-env": "10.1.0",
    "eslint-config-love": "153.0.0",
    "eslint": "10.2.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.9.0",
    "globals": "17.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "livereload": "0.10.3",
    "middleware-axios": "3.0.0",
    "postcss": "8.5.10",
    "prettier": "3.8.3",
    "rimraf": "6.1.3",
    "sass": "1.99.0",
    "typescript": "6.0.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "packageManager": "bun@1.3.13"
}
