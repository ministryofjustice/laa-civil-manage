{
  "name": "laa-express-typescript-template",
  "version": "1.0.1",
  "private": true,
  "license": "MIT",
  "main": "public/index.js",
  "type": "module",
  "imports": {
    "#*": "./*"
  },
  "scripts": {
    "start": "bun public/index.js",
    "clean": "rimraf public",
    "build": "bun run clean && bun esbuild.ts",
    "lint": "bunx eslint . --fix",
    "lint:check": "bunx eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "bun run build && concurrently \"bun esbuild.ts --watch\" \"bun --watch src/index.ts\"",
    "deploy": "./scripts/deploy.sh",
    "prepare": "husky",
    "tsc": "tsc --noEmit",
    "build:ts": "tsc",
    "security:zap:ci": "./deploy/scripts/zap/zap-run-cicd.sh",
    "security:zap:local": "./deploy/scripts/zap/zap-run-local.sh",
    "test": "bun test"
  },
  "engines": {
    "bun": ">=1.2.0"
  },
  "dependencies": {
    "@azure/msal-node": "^5.1.1",
    "@ministryofjustice/frontend": "^9.0.0",
    "axios": "1.13.6",
    "body-parser": "^2.2.2",
    "chalk": "^5.6.2",
    "compression": "^1.8.1",
    "connect-redis": "^9.0.0",
    "cookie-parser": "~1.4.6",
    "csrf-sync": "^4.2.1",
    "debug": "~4.4.3",
    "dotenv": "^17.3.1",
    "eslint-plugin-unused-imports": "^4.4.1",
    "express": "^5.2.1",
    "express-prom-bundle": "^8.0.0",
    "express-rate-limit": "^8.3.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.1",
    "figlet": "^1.11.0",
    "fs-extra": "^11.3.4",
    "govuk-frontend": "^6.1.0",
    "helmet": "^8.1.0",
    "http-errors": "~2.0.1",
    "i18next": "^25.8.20",
    "jwks-rsa": "^4.0.1",
    "libphonenumber-js": "^1.12.40",
    "moment": "^2.30.1",
    "nunjucks": "^3.2.4",
    "prom-client": "^15.1.3",
    "redis": "^5.11.0",
    "tar": "^7.5.11",
    "validator": "^13.15.26"
  },
  "devDependencies": {
    "@eslint/js": "9.39.3",
    "@types/bun": "^1.3.11",
    "@types/chai": "5.2.3",
    "@types/compression": "1.8.1",
    "@types/connect-livereload": "0.6.3",
    "@types/cookie-parser": "1.4.10",
    "@types/express": "5.0.6",
    "@types/express-session": "1.18.2",
    "@types/figlet": "1.7.0",
    "@types/fs-extra": "11.0.4",
    "@types/jsdom": "28.0.0",
    "@types/livereload": "0.9.5",
    "@types/mocha": "10.0.10",
    "@types/node": "25.5.0",
    "@types/nunjucks": "3.2.6",
    "@types/validator": "13.15.10",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "axe-core": "4.11.1",
    "c8": "11.0.0",
    "chokidar": "5.0.0",
    "concurrently": "9.2.1",
    "connect-livereload": "0.6.1",
    "cross-env": "10.1.0",
    "esbuild": "0.27.4",
    "esbuild-plugin-copy": "2.1.1",
    "esbuild-sass-plugin": "3.7.0",
    "eslint": "9.39.4",
    "eslint-config-love": "151.0.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-jsdoc": "62.8.0",
    "globals": "17.4.0",
    "husky": "9.1.7",
    "jsdom": "29.0.1",
    "lint-staged": "16.4.0",
    "livereload": "0.10.3",
    "middleware-axios": "3.0.0",
    "msw": "2.12.10",
    "postcss": "8.5.8",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "sass": "^1.98.0",
    "sass-embedded": "1.98.0",
    "ts-node": "10.9.2",
    "tsx": "4.21.0",
    "typescript": "5.9.3"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "*.{js,ts}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "packageManager": "bun@1.3.11"
}
